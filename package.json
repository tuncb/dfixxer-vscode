{
  "name": "dfixxer-vscode",
  "displayName": "dfixxer",
  "description": "VS Code integration for the dfixxer Pascal formatter.",
  "version": "0.1.1",
  "publisher": "tuncb",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tuncb/dfixxer-vscode.git"
  },
  "engines": {
    "vscode": "^1.97.0",
    "node": ">=22"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "pascal",
    "delphi",
    "formatter",
    "dfixxer"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:pascal",
    "onLanguage:objectpascal",
    "onCommand:dfixxer.createConfig",
    "onCommand:dfixxer.fixCurrentFile",
    "onCommand:dfixxer.updateExecutable"
  ],
  "contributes": {
    "languages": [
      {
        "id": "pascal",
        "aliases": [
          "Pascal"
        ],
        "extensions": [
          ".pas",
          ".pp"
        ]
      },
      {
        "id": "objectpascal",
        "aliases": [
          "Object Pascal"
        ],
        "extensions": [
          ".dpr",
          ".dpk",
          ".lpr"
        ]
      }
    ],
    "commands": [
      {
        "command": "dfixxer.createConfig",
        "title": "dfixxer: Create Configuration File",
        "category": "dfixxer"
      },
      {
        "command": "dfixxer.fixCurrentFile",
        "title": "dfixxer: Fix Current File",
        "category": "dfixxer"
      },
      {
        "command": "dfixxer.updateExecutable",
        "title": "dfixxer: Update dfixxer",
        "category": "dfixxer"
      }
    ],
    "configuration": {
      "title": "dfixxer",
      "properties": {
        "dfixxer.configurationFile": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "markdownDescription": "Path to a `dfixxer` configuration file. Leave empty to use the default resolution behavior."
        },
        "dfixxer.formatOnSave": {
          "type": "boolean",
          "default": false,
          "scope": "resource",
          "markdownDescription": "Run `dfixxer` after saving Pascal files."
        },
        "dfixxer.executablePath": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "markdownDescription": "Path to a `dfixxer` executable. Leave empty to use the managed binary."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "bundle": "node ./esbuild.mjs",
    "vscode:prepublish": "npm run bundle",
    "watch": "tsc -w -p ./",
    "lint": "eslint \"src/**/*.ts\"",
    "test:unit": "mocha --config .mocharc.unit.json",
    "test:extension": "npm run bundle && node ./out/test/runTest.js",
    "test": "npm run compile && npm run lint && npm run test:unit && npm run test:extension",
    "package": "vsce package"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.13.10",
    "@types/vscode": "^1.97.0",
    "@types/yazl": "^3.3.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.2.2",
    "esbuild": "^0.25.1",
    "eslint": "^9.21.0",
    "glob": "^11.0.1",
    "mocha": "^11.1.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.25.0",
    "yazl": "^3.3.1"
  },
  "dependencies": {
    "extract-zip": "^2.0.1",
    "tar": "^7.5.11"
  }
}
